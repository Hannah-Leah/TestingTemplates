@model TestingTemplates.Models.Robot

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>Robot</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="RobDescription" class="control-label"></label>
                <input asp-for="RobDescription" class="form-control" />
                <span asp-validation-for="RobDescription" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="RobType" class="control-label"></label>
                <input asp-for="RobType" class="form-control" />
                <span asp-validation-for="RobType" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="RobColor" class="control-label"></label>
                <!--Color picker-->
                <input type="color" asp-for="RobColor" class="form-control" />
                <span asp-validation-for="RobColor" class="text-danger"></span>
            </div>
            @* <div class="form-group">
                <label asp-for="RobStatus" class="control-label"></label>
                <input asp-for="RobStatus" class="form-control" />
                <span asp-validation-for="RobStatus" class="text-danger"></span>
            </div> *@

            <div class="form-group">
                <label asp-for="RobStatus" class="control-label"></label>
                <select asp-for="RobStatus" class="form-control">
                    <option>Bitte status wählen</option>
                    <option value="0">Online</option>
                    <option value="1">Standby</option>
                    <option value="2">Offline</option>
                    <option value="3">In Reparatur</option>
                    <option value="4">Außer Betrieb</option>
                </select>
                <span asp-validation-for="RobStatus" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
